{
  "name": "v2ex-playground",
  "icon": "resources/icon.png",
  "displayName": "V2EX Playground",
  "description": "V2EX 游乐场，上班时用来放（mō）松（yú）的插件",
  "version": "1.6.1",
  "publisher": "chaselen",
  "repository": {
    "type": "git",
    "url": "https://github.com/chaselen/v2ex-playground"
  },
  "engines": {
    "vscode": "^1.86.0",
    "node": ">=22.18.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "v2ex"
  ],
  "type": "module",
  "main": "./out/extension.cjs",
  "contributes": {
    "commands": [
      {
        "command": "v2ex.login",
        "title": "登录V2EX",
        "icon": "$(sign-in)"
      },
      {
        "command": "v2ex-main.search",
        "title": "搜索",
        "icon": "$(search)"
      },
      {
        "command": "v2ex-main.settings",
        "title": "设置",
        "icon": "$(gear)"
      },
      {
        "command": "v2ex-main.refresh",
        "title": "刷新",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "v2ex",
          "title": "V2EX",
          "icon": "resources/v.svg"
        }
      ]
    },
    "views": {
      "v2ex": [
        {
          "id": "v2ex-main",
          "name": "V2EX",
          "icon": "resources/v.svg",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "v2ex-main.refresh",
          "when": "view == v2ex-main",
          "group": "navigation@0"
        },
        {
          "command": "v2ex-main.search",
          "when": "view == v2ex-main",
          "group": "navigation@1"
        },
        {
          "command": "v2ex-main.settings",
          "when": "view == v2ex-main",
          "group": "navigation@2"
        },
        {
          "command": "v2ex.login",
          "when": "view == v2ex-main",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "V2EX Playground",
      "properties": {
        "v2ex.browse.openInNewTab": {
          "type": "boolean",
          "default": true,
          "description": "始终在新标签页中打开帖子"
        },
        "v2ex.browse.autoSignIn": {
          "type": "boolean",
          "default": true,
          "description": "登录后自动进行每日签到"
        },
        "v2ex.browse.showImagesInTopic": {
          "type": "boolean",
          "default": true,
          "description": "查看帖子时显示图片"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run typecheck && npm run build:webview && node esbuild.config.ts --production",
    "build:webview": "vite build --config webview/vite.config.ts",
    "check:webview": "tsc -p webview/tsconfig.json --noEmit",
    "compile": "npm run build:webview && node esbuild.config.ts",
    "test": "npm run test:v2ex",
    "test:v2ex": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p ./ --noEmit",
    "watch:webview": "vite build --watch --config webview/vite.config.ts",
    "watch:extension": "node esbuild.config.ts --watch",
    "watch:typecheck": "tsc -p ./ --noEmit --watch",
    "watch": "npm run watch:webview & npm run watch:extension & npm run watch:typecheck",
    "package": "npx @vscode/vsce@3.9.1 package",
    "publish": "npx @vscode/vsce@3.9.1 publish"
  },
  "devDependencies": {
    "@douyinfe/semi-icons": "^2.99.2",
    "@douyinfe/semi-ui": "^2.99.2",
    "@types/node": "^22.18.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "~1.86.0",
    "@types/vscode-webview": "^1.57.5",
    "@vitejs/plugin-react": "^6.0.2",
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.21",
    "esbuild": "^0.28.0",
    "file-type": "^22.0.1",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sass": "^1.100.0",
    "simplebar-react": "^3.3.2",
    "typescript": "^5.8.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
